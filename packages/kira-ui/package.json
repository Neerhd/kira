{
  "name": "@neerhd/kira-ui",
  "version": "0.2.0",
  "description": "Kira — component library and design token system",
  "main": "./dist/kira-ui.umd.js",
  "module": "./dist/kira-ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/kira-ui.es.js",
      "require": "./dist/kira-ui.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/style.css",
    "./tokens": "./src/tokens/kira-tokens-v2.json"
  },
  "type": "module",
  "files": ["dist", "src/tokens", "scripts/check-setup.js"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "generate-tokens": "tsx scripts/generate-tokens.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0"
  }
}
